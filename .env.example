# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
HELIUS_API_KEY=your-helius-api-key

# ─── Wallet Tracking ─────────────────────────────────────────────────────────
SEED_WALLETS=addr1,addr2    # additional wallets to track (comma-separated)
MIN_TRANSFER_SOL=100        # ignore moves below this SOL amount

# ─── Agent ───────────────────────────────────────────────────────────────────
ALERT_MIN_CONFIDENCE=0.70
MAX_TXS_PER_WALLET=10

# ─── Scanner ─────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MS=60000      # 1 minute

# ─── Model ───────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
